# frontend/.env.example
# Copy to frontend/.env.local and adjust as needed.
# NEXT_PUBLIC_ vars are exposed to the browser.

# Base URL of the backend API.
#
# RECOMMENDED: leave EMPTY. The frontend auto-detects the backend at
# `<same-host>:5000` in the browser, so the same build works on localhost,
# EC2, or any other host with no rebuild.
#
# Set this only if your backend is on a *different* domain than the frontend
# (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=
