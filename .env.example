# .env.example — root-level secrets consumed by docker-compose.
# Copy to .env and fill in real values before running docker-compose.
# NEVER commit .env to git.

# ── PostgreSQL ──────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change-me-db-password
DB_NAME=cviator

# ── JWT ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Root administrator ──────────────────────────────────────────────
# The email address that becomes the institution's root admin. The first
# admin signup matching this address is auto-approved. Every other admin
# signup requires the root admin's approval. Required for admin signups.
ROOT_ADMIN_EMAIL=root.admin@giki.edu.pk

# ── URLs ────────────────────────────────────────────────────────────
# CORS allow-list for the backend. Comma-separated, or '*' to allow any
# origin. Default '*' is fine for the student project / EC2 demo.
# Example for stricter prod: FRONTEND_URL=http://13.60.66.182:3000
FRONTEND_URL=*

# Leave EMPTY to auto-detect the backend at <same-host>:5000 in the browser.
# This makes the SAME built image work on localhost AND any EC2 IP.
# Override only if backend is on a different domain (e.g. https://api.example.com)
NEXT_PUBLIC_API_URL=

# ── Docker Hub (for CI/CD push & docker-compose pull) ───────────────
# Used to tag images as <DOCKERHUB_USERNAME>/cviator-backend:latest etc.
DOCKERHUB_USERNAME=

# ── SMTP (leave blank to skip email sending and log links to console) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
